{
  "additionalProperties": false,
  "description": "Content-free evidence for a deterministic Train downsampling decision.",
  "properties": {
    "content_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Content Sha256",
      "type": "string"
    },
    "language": {
      "enum": [
        "en",
        "zh"
      ],
      "title": "Language",
      "type": "string"
    },
    "reason": {
      "const": "balance_downsampled",
      "title": "Reason",
      "type": "string"
    },
    "sample_id": {
      "pattern": "^(oasst1|commitpackft):[a-zA-Z0-9._-]+$",
      "title": "Sample Id",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "source": {
      "enum": [
        "oasst1",
        "commitpackft"
      ],
      "title": "Source",
      "type": "string"
    },
    "split": {
      "const": "train",
      "title": "Split",
      "type": "string"
    },
    "stratum": {
      "enum": [
        "oasst1:zh",
        "oasst1:en",
        "commitpackft:en"
      ],
      "title": "Stratum",
      "type": "string"
    },
    "token_count": {
      "exclusiveMinimum": 0,
      "title": "Token Count",
      "type": "integer"
    }
  },
  "required": [
    "sample_id",
    "source",
    "split",
    "language",
    "stratum",
    "content_sha256",
    "token_count",
    "reason"
  ],
  "title": "BalanceRejectedRecord",
  "type": "object"
}

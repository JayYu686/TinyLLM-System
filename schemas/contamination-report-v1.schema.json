{
  "$defs": {
    "ContaminationMatch": {
      "additionalProperties": false,
      "description": "Content-free evidence that one evaluation fingerprint matched Train.",
      "properties": {
        "evaluation_item_id": {
          "pattern": "^domain-(config|json|linux|logs|python|refusal|short-code)-[0-9]{3}$",
          "title": "Evaluation Item Id",
          "type": "string"
        },
        "fingerprint_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Fingerprint Sha256",
          "type": "string"
        },
        "match_kind": {
          "enum": [
            "full_sequence",
            "prompt_prefix"
          ],
          "title": "Match Kind",
          "type": "string"
        },
        "training_sample_id_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Training Sample Id Sha256",
          "type": "string"
        }
      },
      "required": [
        "evaluation_item_id",
        "match_kind",
        "fingerprint_sha256",
        "training_sample_id_sha256"
      ],
      "title": "ContaminationMatch",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Path-free stable result of exact Train/evaluation fingerprint comparison.",
  "properties": {
    "checked_evaluation_items": {
      "exclusiveMinimum": 0,
      "title": "Checked Evaluation Items",
      "type": "integer"
    },
    "checked_training_samples": {
      "minimum": 0,
      "title": "Checked Training Samples",
      "type": "integer"
    },
    "contaminated_items": {
      "minimum": 0,
      "title": "Contaminated Items",
      "type": "integer"
    },
    "dataset_content_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Dataset Content Sha256",
      "type": "string"
    },
    "dataset_version": {
      "pattern": "^m2-sft-v1-[0-9a-f]{8}$",
      "title": "Dataset Version",
      "type": "string"
    },
    "evaluation_content_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Evaluation Content Sha256",
      "type": "string"
    },
    "evaluation_suite_version": {
      "pattern": "^[a-z][a-z0-9-]{2,63}-v1-[0-9a-f]{8}$",
      "title": "Evaluation Suite Version",
      "type": "string"
    },
    "fingerprint_algorithm": {
      "const": "token-sequence-sha256-v1",
      "title": "Fingerprint Algorithm",
      "type": "string"
    },
    "full_sequence_matches": {
      "minimum": 0,
      "title": "Full Sequence Matches",
      "type": "integer"
    },
    "matches": {
      "items": {
        "$ref": "#/$defs/ContaminationMatch"
      },
      "title": "Matches",
      "type": "array"
    },
    "near_dedup": {
      "const": "not_evaluated",
      "title": "Near Dedup",
      "type": "string"
    },
    "prompt_prefix_matches": {
      "minimum": 0,
      "title": "Prompt Prefix Matches",
      "type": "integer"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "enum": [
        "clean",
        "contaminated"
      ],
      "title": "Status",
      "type": "string"
    }
  },
  "required": [
    "status",
    "fingerprint_algorithm",
    "near_dedup",
    "evaluation_suite_version",
    "evaluation_content_sha256",
    "dataset_version",
    "dataset_content_sha256",
    "checked_evaluation_items",
    "checked_training_samples",
    "contaminated_items",
    "full_sequence_matches",
    "prompt_prefix_matches",
    "matches"
  ],
  "title": "ContaminationReport",
  "type": "object"
}

{
  "additionalProperties": false,
  "description": "Metadata required to reconstruct and validate one Pack from shard arrays.",
  "properties": {
    "max_sequence_length": {
      "exclusiveMinimum": 1,
      "title": "Max Sequence Length",
      "type": "integer"
    },
    "pack_id": {
      "pattern": "^(train|validation|test)-[0-9a-f]{16}$",
      "title": "Pack Id",
      "type": "string"
    },
    "pack_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Pack Sha256",
      "type": "string"
    },
    "sample_ids": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Sample Ids",
      "type": "array"
    },
    "sample_token_counts": {
      "items": {
        "type": "integer"
      },
      "minItems": 1,
      "title": "Sample Token Counts",
      "type": "array"
    },
    "supervised_token_count": {
      "exclusiveMinimum": 0,
      "title": "Supervised Token Count",
      "type": "integer"
    },
    "token_count": {
      "exclusiveMinimum": 0,
      "title": "Token Count",
      "type": "integer"
    }
  },
  "required": [
    "pack_id",
    "pack_sha256",
    "max_sequence_length",
    "sample_ids",
    "sample_token_counts",
    "token_count",
    "supervised_token_count"
  ],
  "title": "DatasetShardPack",
  "type": "object"
}

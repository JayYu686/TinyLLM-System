{
  "$defs": {
    "BenchmarkDataConfig": {
      "additionalProperties": false,
      "description": "Deterministic synthetic data semantics used for systems measurement.",
      "properties": {
        "kind": {
          "const": "toy",
          "default": "toy",
          "title": "Kind",
          "type": "string"
        },
        "sequence_length": {
          "minimum": 2,
          "title": "Sequence Length",
          "type": "integer"
        },
        "vocab_size": {
          "minimum": 2,
          "title": "Vocab Size",
          "type": "integer"
        }
      },
      "required": [
        "vocab_size",
        "sequence_length"
      ],
      "title": "BenchmarkDataConfig",
      "type": "object"
    },
    "BenchmarkDistributedConfig": {
      "additionalProperties": false,
      "description": "Single-node process-group policy.",
      "properties": {
        "backend": {
          "enum": [
            "gloo",
            "nccl"
          ],
          "title": "Backend",
          "type": "string"
        },
        "broadcast_buffers": {
          "const": false,
          "default": false,
          "title": "Broadcast Buffers",
          "type": "boolean"
        },
        "find_unused_parameters": {
          "const": false,
          "default": false,
          "title": "Find Unused Parameters",
          "type": "boolean"
        },
        "timeout_seconds": {
          "default": 300,
          "maximum": 3600,
          "minimum": 10,
          "title": "Timeout Seconds",
          "type": "integer"
        }
      },
      "required": [
        "backend"
      ],
      "title": "BenchmarkDistributedConfig",
      "type": "object"
    },
    "BenchmarkPrecisionConfig": {
      "additionalProperties": false,
      "description": "Numerical policy for a benchmark host.",
      "properties": {
        "allow_tf32": {
          "title": "Allow Tf32",
          "type": "boolean"
        },
        "dtype": {
          "enum": [
            "fp32",
            "bf16"
          ],
          "title": "Dtype",
          "type": "string"
        },
        "use_grad_scaler": {
          "const": false,
          "default": false,
          "title": "Use Grad Scaler",
          "type": "boolean"
        }
      },
      "required": [
        "dtype",
        "allow_tf32"
      ],
      "title": "BenchmarkPrecisionConfig",
      "type": "object"
    },
    "BenchmarkRunConfig": {
      "additionalProperties": false,
      "description": "Stable benchmark identity and independent-repeat seed.",
      "properties": {
        "name": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "seed": {
          "maximum": 4294967292,
          "minimum": 0,
          "title": "Seed",
          "type": "integer"
        }
      },
      "required": [
        "name",
        "seed"
      ],
      "title": "BenchmarkRunConfig",
      "type": "object"
    },
    "BenchmarkTrainingConfig": {
      "additionalProperties": false,
      "description": "Optimizer and batch semantics shared by all benchmark profiles.",
      "properties": {
        "learning_rate": {
          "exclusiveMinimum": 0,
          "title": "Learning Rate",
          "type": "number"
        },
        "learning_rate_warmup_steps": {
          "minimum": 0,
          "title": "Learning Rate Warmup Steps",
          "type": "integer"
        },
        "max_grad_norm": {
          "exclusiveMinimum": 0,
          "title": "Max Grad Norm",
          "type": "number"
        },
        "micro_batch_size": {
          "exclusiveMinimum": 0,
          "title": "Micro Batch Size",
          "type": "integer"
        },
        "strong_global_batch_size": {
          "exclusiveMinimum": 0,
          "title": "Strong Global Batch Size",
          "type": "integer"
        },
        "weak_per_rank_batch_size": {
          "exclusiveMinimum": 0,
          "title": "Weak Per Rank Batch Size",
          "type": "integer"
        },
        "weight_decay": {
          "minimum": 0,
          "title": "Weight Decay",
          "type": "number"
        }
      },
      "required": [
        "micro_batch_size",
        "strong_global_batch_size",
        "weak_per_rank_batch_size",
        "learning_rate",
        "weight_decay",
        "max_grad_norm",
        "learning_rate_warmup_steps"
      ],
      "title": "BenchmarkTrainingConfig",
      "type": "object"
    },
    "BenchmarkWindowConfig": {
      "additionalProperties": false,
      "description": "Warmup, measurement, repetition, and Profiler windows.",
      "properties": {
        "measurement_steps": {
          "exclusiveMinimum": 0,
          "title": "Measurement Steps",
          "type": "integer"
        },
        "profiler_repeat": {
          "exclusiveMinimum": 0,
          "title": "Profiler Repeat",
          "type": "integer"
        },
        "profiler_steps": {
          "minimum": 0,
          "title": "Profiler Steps",
          "type": "integer"
        },
        "repetitions": {
          "exclusiveMinimum": 0,
          "maximum": 10,
          "title": "Repetitions",
          "type": "integer"
        },
        "telemetry_interval_seconds": {
          "exclusiveMinimum": 0,
          "maximum": 60,
          "title": "Telemetry Interval Seconds",
          "type": "number"
        },
        "warmup_steps": {
          "minimum": 0,
          "title": "Warmup Steps",
          "type": "integer"
        }
      },
      "required": [
        "warmup_steps",
        "measurement_steps",
        "repetitions",
        "profiler_steps",
        "profiler_repeat",
        "telemetry_interval_seconds"
      ],
      "title": "BenchmarkWindowConfig",
      "type": "object"
    },
    "TinyGPTConfig": {
      "additionalProperties": false,
      "description": "Strict, immutable architecture parameters for TinyGPT.",
      "properties": {
        "dropout": {
          "default": 0.0,
          "exclusiveMaximum": 1.0,
          "minimum": 0.0,
          "title": "Dropout",
          "type": "number"
        },
        "hidden_size": {
          "default": 192,
          "exclusiveMinimum": 0,
          "title": "Hidden Size",
          "type": "integer"
        },
        "intermediate_size": {
          "default": 512,
          "exclusiveMinimum": 0,
          "title": "Intermediate Size",
          "type": "integer"
        },
        "max_sequence_length": {
          "default": 128,
          "minimum": 2,
          "title": "Max Sequence Length",
          "type": "integer"
        },
        "num_heads": {
          "default": 6,
          "exclusiveMinimum": 0,
          "title": "Num Heads",
          "type": "integer"
        },
        "num_layers": {
          "default": 4,
          "exclusiveMinimum": 0,
          "title": "Num Layers",
          "type": "integer"
        },
        "rms_norm_epsilon": {
          "default": 1e-06,
          "exclusiveMinimum": 0,
          "title": "Rms Norm Epsilon",
          "type": "number"
        },
        "rope_theta": {
          "default": 10000.0,
          "exclusiveMinimum": 0,
          "title": "Rope Theta",
          "type": "number"
        },
        "tie_word_embeddings": {
          "default": true,
          "title": "Tie Word Embeddings",
          "type": "boolean"
        },
        "vocab_size": {
          "default": 256,
          "minimum": 2,
          "title": "Vocab Size",
          "type": "integer"
        }
      },
      "title": "TinyGPTConfig",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Complete, immutable DDP benchmark YAML.",
  "properties": {
    "benchmark": {
      "$ref": "#/$defs/BenchmarkWindowConfig"
    },
    "data": {
      "$ref": "#/$defs/BenchmarkDataConfig"
    },
    "distributed": {
      "$ref": "#/$defs/BenchmarkDistributedConfig"
    },
    "model": {
      "$ref": "#/$defs/TinyGPTConfig"
    },
    "precision": {
      "$ref": "#/$defs/BenchmarkPrecisionConfig"
    },
    "run": {
      "$ref": "#/$defs/BenchmarkRunConfig"
    },
    "schema_version": {
      "const": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "training": {
      "$ref": "#/$defs/BenchmarkTrainingConfig"
    }
  },
  "required": [
    "schema_version",
    "run",
    "model",
    "data",
    "training",
    "benchmark",
    "precision",
    "distributed"
  ],
  "title": "DDPBenchmarkConfig",
  "type": "object"
}

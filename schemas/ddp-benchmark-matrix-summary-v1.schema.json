{
  "$defs": {
    "BenchmarkProfileAggregate": {
      "additionalProperties": false,
      "description": "Three-repeat summary for one controlled matrix cell.",
      "properties": {
        "data_wait_percent_median": {
          "minimum": 0,
          "title": "Data Wait Percent Median",
          "type": "number"
        },
        "gpu_indices": {
          "items": {
            "type": "integer"
          },
          "title": "Gpu Indices",
          "type": "array"
        },
        "group": {
          "enum": [
            "standard",
            "same_numa",
            "cross_numa"
          ],
          "title": "Group",
          "type": "string"
        },
        "peak_memory_bytes_median": {
          "minimum": 0,
          "title": "Peak Memory Bytes Median",
          "type": "number"
        },
        "profile": {
          "enum": [
            "strong",
            "weak"
          ],
          "title": "Profile",
          "type": "string"
        },
        "repeats": {
          "items": {
            "enum": [
              1,
              2,
              3
            ],
            "type": "integer"
          },
          "title": "Repeats",
          "type": "array"
        },
        "run_ids": {
          "items": {
            "type": "string"
          },
          "title": "Run Ids",
          "type": "array"
        },
        "scaling_efficiency": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Scaling Efficiency"
        },
        "step_time_ms_median": {
          "exclusiveMinimum": 0,
          "title": "Step Time Ms Median",
          "type": "number"
        },
        "tokens_per_second_max": {
          "exclusiveMinimum": 0,
          "title": "Tokens Per Second Max",
          "type": "number"
        },
        "tokens_per_second_median": {
          "exclusiveMinimum": 0,
          "title": "Tokens Per Second Median",
          "type": "number"
        },
        "tokens_per_second_min": {
          "exclusiveMinimum": 0,
          "title": "Tokens Per Second Min",
          "type": "number"
        },
        "world_size": {
          "maximum": 10,
          "minimum": 1,
          "title": "World Size",
          "type": "integer"
        }
      },
      "required": [
        "group",
        "profile",
        "world_size",
        "gpu_indices",
        "repeats",
        "run_ids",
        "tokens_per_second_median",
        "tokens_per_second_min",
        "tokens_per_second_max",
        "step_time_ms_median",
        "peak_memory_bytes_median",
        "data_wait_percent_median"
      ],
      "title": "BenchmarkProfileAggregate",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Strict acceptance summary for the complete M3.3/M3.4 matrix.",
  "properties": {
    "base_config_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Base Config Sha256",
      "type": "string"
    },
    "git_commit": {
      "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$",
      "title": "Git Commit",
      "type": "string"
    },
    "model_parameter_count": {
      "exclusiveMinimum": 0,
      "title": "Model Parameter Count",
      "type": "integer"
    },
    "numa": {
      "items": {
        "$ref": "#/$defs/BenchmarkProfileAggregate"
      },
      "title": "Numa",
      "type": "array"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "standard": {
      "items": {
        "$ref": "#/$defs/BenchmarkProfileAggregate"
      },
      "title": "Standard",
      "type": "array"
    },
    "status": {
      "const": "pass",
      "default": "pass",
      "title": "Status",
      "type": "string"
    }
  },
  "required": [
    "base_config_sha256",
    "git_commit",
    "model_parameter_count",
    "standard",
    "numa"
  ],
  "title": "DDPBenchmarkMatrixSummary",
  "type": "object"
}

{
  "$defs": {
    "FSDP2CheckpointConfig": {
      "additionalProperties": false,
      "description": "DCP publication and rolling-retention policy for M4.2.",
      "properties": {
        "keep_last": {
          "exclusiveMinimum": 0,
          "title": "Keep Last",
          "type": "integer"
        },
        "save_steps": {
          "exclusiveMinimum": 0,
          "title": "Save Steps",
          "type": "integer"
        }
      },
      "required": [
        "save_steps",
        "keep_last"
      ],
      "title": "FSDP2CheckpointConfig",
      "type": "object"
    },
    "FSDP2PolicyConfig": {
      "additionalProperties": false,
      "description": "Explicit FSDP2 sharding policy for the bounded correctness gate.",
      "properties": {
        "activation_checkpointing": {
          "default": false,
          "title": "Activation Checkpointing",
          "type": "boolean"
        },
        "backend": {
          "enum": [
            "gloo",
            "nccl"
          ],
          "title": "Backend",
          "type": "string"
        },
        "cpu_offload": {
          "const": false,
          "default": false,
          "title": "Cpu Offload",
          "type": "boolean"
        },
        "device_type": {
          "enum": [
            "cpu",
            "cuda"
          ],
          "title": "Device Type",
          "type": "string"
        },
        "reshard_after_forward": {
          "const": true,
          "default": true,
          "title": "Reshard After Forward",
          "type": "boolean"
        },
        "strategy": {
          "const": "fsdp2",
          "title": "Strategy",
          "type": "string"
        },
        "timeout_seconds": {
          "default": 120,
          "maximum": 1800,
          "minimum": 10,
          "title": "Timeout Seconds",
          "type": "integer"
        },
        "world_size": {
          "maximum": 4,
          "minimum": 1,
          "title": "World Size",
          "type": "integer"
        }
      },
      "required": [
        "strategy",
        "backend",
        "device_type",
        "world_size"
      ],
      "title": "FSDP2PolicyConfig",
      "type": "object"
    },
    "M4QwenDataConfig": {
      "additionalProperties": false,
      "description": "Deterministic registered-data view used by the bounded four-GPU run.",
      "properties": {
        "assistant_only_loss": {
          "const": true,
          "title": "Assistant Only Loss",
          "type": "boolean"
        },
        "dataset_version": {
          "const": "m2-sft-v1-f82ff32e",
          "title": "Dataset Version",
          "type": "string"
        },
        "max_sequences": {
          "maximum": 4096,
          "minimum": 200,
          "title": "Max Sequences",
          "type": "integer"
        },
        "pad_token_id": {
          "const": 151643,
          "title": "Pad Token Id",
          "type": "integer"
        },
        "sequence_length": {
          "const": 512,
          "title": "Sequence Length",
          "type": "integer"
        },
        "slice_position_ids_reset": {
          "const": true,
          "title": "Slice Position Ids Reset",
          "type": "boolean"
        },
        "split": {
          "const": "train",
          "title": "Split",
          "type": "string"
        }
      },
      "required": [
        "dataset_version",
        "split",
        "sequence_length",
        "max_sequences",
        "pad_token_id",
        "assistant_only_loss",
        "slice_position_ids_reset"
      ],
      "title": "M4QwenDataConfig",
      "type": "object"
    },
    "M4QwenModelConfig": {
      "additionalProperties": false,
      "description": "Immutable model identity and safe local-loading policy.",
      "properties": {
        "license": {
          "const": "Apache-2.0",
          "title": "License",
          "type": "string"
        },
        "model_type": {
          "const": "qwen3",
          "title": "Model Type",
          "type": "string"
        },
        "repository": {
          "const": "Qwen/Qwen3-8B",
          "title": "Repository",
          "type": "string"
        },
        "revision": {
          "const": "b968826d9c46dd6066d109eabc6255188de91218",
          "title": "Revision",
          "type": "string"
        },
        "trust_remote_code": {
          "const": false,
          "default": false,
          "title": "Trust Remote Code",
          "type": "boolean"
        }
      },
      "required": [
        "repository",
        "revision",
        "model_type",
        "license"
      ],
      "title": "M4QwenModelConfig",
      "type": "object"
    },
    "PrecisionConfig": {
      "additionalProperties": false,
      "description": "Numerical precision policy for one hardware profile.",
      "properties": {
        "allow_tf32": {
          "title": "Allow Tf32",
          "type": "boolean"
        },
        "dtype": {
          "enum": [
            "fp32",
            "bf16",
            "fp16"
          ],
          "title": "Dtype",
          "type": "string"
        },
        "use_grad_scaler": {
          "title": "Use Grad Scaler",
          "type": "boolean"
        }
      },
      "required": [
        "dtype",
        "allow_tf32",
        "use_grad_scaler"
      ],
      "title": "PrecisionConfig",
      "type": "object"
    },
    "RunConfig": {
      "additionalProperties": false,
      "description": "Human identity and random seed for one training run.",
      "properties": {
        "name": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "seed": {
          "maximum": 4294967295,
          "minimum": 0,
          "title": "Seed",
          "type": "integer"
        }
      },
      "required": [
        "name",
        "seed"
      ],
      "title": "RunConfig",
      "type": "object"
    },
    "TrainingLoopConfig": {
      "additionalProperties": false,
      "description": "Optimizer-step semantics for M1.",
      "properties": {
        "gradient_accumulation_steps": {
          "exclusiveMinimum": 0,
          "title": "Gradient Accumulation Steps",
          "type": "integer"
        },
        "learning_rate": {
          "exclusiveMinimum": 0,
          "title": "Learning Rate",
          "type": "number"
        },
        "max_grad_norm": {
          "exclusiveMinimum": 0,
          "title": "Max Grad Norm",
          "type": "number"
        },
        "max_steps": {
          "exclusiveMinimum": 0,
          "title": "Max Steps",
          "type": "integer"
        },
        "micro_batch_size": {
          "exclusiveMinimum": 0,
          "title": "Micro Batch Size",
          "type": "integer"
        },
        "warmup_steps": {
          "minimum": 0,
          "title": "Warmup Steps",
          "type": "integer"
        },
        "weight_decay": {
          "minimum": 0,
          "title": "Weight Decay",
          "type": "number"
        }
      },
      "required": [
        "max_steps",
        "micro_batch_size",
        "gradient_accumulation_steps",
        "learning_rate",
        "weight_decay",
        "max_grad_norm",
        "warmup_steps"
      ],
      "title": "TrainingLoopConfig",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Complete four-GPU Qwen3-8B M4.3 configuration.",
  "properties": {
    "checkpoint": {
      "$ref": "#/$defs/FSDP2CheckpointConfig"
    },
    "data": {
      "$ref": "#/$defs/M4QwenDataConfig"
    },
    "distributed": {
      "$ref": "#/$defs/FSDP2PolicyConfig"
    },
    "model": {
      "$ref": "#/$defs/M4QwenModelConfig"
    },
    "precision": {
      "$ref": "#/$defs/PrecisionConfig"
    },
    "run": {
      "$ref": "#/$defs/RunConfig"
    },
    "schema_version": {
      "const": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "training": {
      "$ref": "#/$defs/TrainingLoopConfig"
    }
  },
  "required": [
    "schema_version",
    "run",
    "model",
    "data",
    "training",
    "precision",
    "distributed",
    "checkpoint"
  ],
  "title": "M4QwenFSDP2Config",
  "type": "object"
}

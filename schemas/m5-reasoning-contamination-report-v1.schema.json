{
  "$defs": {
    "ReasoningContaminationMatch": {
      "additionalProperties": false,
      "description": "Content-free identity for one Pilot/Dev prompt or template-family overlap.",
      "properties": {
        "dev_identity": {
          "maxLength": 160,
          "minLength": 1,
          "title": "Dev Identity",
          "type": "string"
        },
        "evidence_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Evidence Sha256",
          "type": "string"
        },
        "kind": {
          "enum": [
            "exact_prompt",
            "template_family"
          ],
          "title": "Kind",
          "type": "string"
        },
        "pilot_identity": {
          "maxLength": 160,
          "minLength": 1,
          "title": "Pilot Identity",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "pilot_identity",
        "dev_identity",
        "evidence_sha256"
      ],
      "title": "ReasoningContaminationMatch",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Deterministic Pilot/Dev isolation result required by every M5 pilot Manifest.",
  "properties": {
    "algorithm": {
      "const": "exact-prompt-and-template-family-v1",
      "title": "Algorithm",
      "type": "string"
    },
    "dev_task_count": {
      "const": 200,
      "title": "Dev Task Count",
      "type": "integer"
    },
    "dev_task_set_version": {
      "pattern": "^m5-reasoning-dev-v1-[0-9a-f]{8}$",
      "title": "Dev Task Set Version",
      "type": "string"
    },
    "exact_prompt_matches": {
      "minimum": 0,
      "title": "Exact Prompt Matches",
      "type": "integer"
    },
    "matches": {
      "items": {
        "$ref": "#/$defs/ReasoningContaminationMatch"
      },
      "title": "Matches",
      "type": "array"
    },
    "pilot_task_count": {
      "exclusiveMinimum": 0,
      "title": "Pilot Task Count",
      "type": "integer"
    },
    "pilot_task_set_version": {
      "pattern": "^m5-reasoning-pilot-tasks-v1-[0-9a-f]{8}$",
      "title": "Pilot Task Set Version",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "enum": [
        "pass",
        "fail"
      ],
      "title": "Status",
      "type": "string"
    },
    "template_family_overlaps": {
      "minimum": 0,
      "title": "Template Family Overlaps",
      "type": "integer"
    }
  },
  "required": [
    "algorithm",
    "pilot_task_set_version",
    "dev_task_set_version",
    "pilot_task_count",
    "dev_task_count",
    "exact_prompt_matches",
    "template_family_overlaps",
    "matches",
    "status"
  ],
  "title": "M5ReasoningContaminationReport",
  "type": "object"
}

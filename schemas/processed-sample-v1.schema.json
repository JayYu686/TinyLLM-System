{
  "$defs": {
    "ImportedMessage": {
      "additionalProperties": false,
      "description": "One validated message before normalization and tokenization.",
      "properties": {
        "content": {
          "minLength": 1,
          "title": "Content",
          "type": "string"
        },
        "role": {
          "enum": [
            "system",
            "user",
            "assistant"
          ],
          "title": "Role",
          "type": "string"
        }
      },
      "required": [
        "role",
        "content"
      ],
      "title": "ImportedMessage",
      "type": "object"
    },
    "ImportedSampleMetadata": {
      "additionalProperties": false,
      "description": "Lineage and grouping metadata retained through the M2 pipeline.",
      "properties": {
        "category": {
          "enum": [
            "conversation",
            "code_edit"
          ],
          "title": "Category",
          "type": "string"
        },
        "group_ids": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Group Ids",
          "type": "array"
        },
        "language": {
          "pattern": "^[a-z][a-z0-9-]{1,15}$",
          "title": "Language",
          "type": "string"
        },
        "license": {
          "maxLength": 64,
          "minLength": 1,
          "title": "License",
          "type": "string"
        },
        "raw_record_sha256s": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Raw Record Sha256S",
          "type": "array"
        },
        "source_record_id": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Source Record Id",
          "type": "string"
        },
        "source_revision": {
          "pattern": "^[0-9a-f]{40}$",
          "title": "Source Revision",
          "type": "string"
        }
      },
      "required": [
        "language",
        "category",
        "license",
        "source_revision",
        "source_record_id",
        "group_ids",
        "raw_record_sha256s"
      ],
      "title": "ImportedSampleMetadata",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Normalized, exact-deduplicated, and leakage-safe split sample.",
  "properties": {
    "component_id": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Component Id",
      "type": "string"
    },
    "content_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Content Sha256",
      "type": "string"
    },
    "group_keys": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Group Keys",
      "type": "array"
    },
    "id": {
      "pattern": "^(oasst1|commitpackft):[a-zA-Z0-9._-]+$",
      "title": "Id",
      "type": "string"
    },
    "messages": {
      "items": {
        "$ref": "#/$defs/ImportedMessage"
      },
      "minItems": 2,
      "title": "Messages",
      "type": "array"
    },
    "metadata": {
      "$ref": "#/$defs/ImportedSampleMetadata"
    },
    "origin_record_sha256s": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Origin Record Sha256S",
      "type": "array"
    },
    "origin_sample_ids": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Origin Sample Ids",
      "type": "array"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "source": {
      "enum": [
        "oasst1",
        "commitpackft"
      ],
      "title": "Source",
      "type": "string"
    },
    "split": {
      "enum": [
        "train",
        "validation",
        "test"
      ],
      "title": "Split",
      "type": "string"
    }
  },
  "required": [
    "id",
    "source",
    "messages",
    "metadata",
    "content_sha256",
    "origin_sample_ids",
    "origin_record_sha256s",
    "group_keys",
    "component_id",
    "split"
  ],
  "title": "ProcessedSample",
  "type": "object"
}

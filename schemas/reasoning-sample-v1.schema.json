{
  "additionalProperties": false,
  "description": "One accepted visible-reasoning SFT sample with complete private lineage.",
  "properties": {
    "content_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Content Sha256",
      "type": "string"
    },
    "final_answer": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Final Answer",
      "type": "string"
    },
    "generation_id": {
      "pattern": "^m5-reasoning:pilot:[a-z0-9][a-z0-9._-]{2,95}:candidate-[01]$",
      "title": "Generation Id",
      "type": "string"
    },
    "id": {
      "pattern": "^m5-reasoning-sample:[a-z0-9][a-z0-9._-]{2,95}$",
      "title": "Id",
      "type": "string"
    },
    "language": {
      "enum": [
        "en",
        "zh"
      ],
      "title": "Language",
      "type": "string"
    },
    "observed_token_count": {
      "exclusiveMinimum": 0,
      "maximum": 1024,
      "title": "Observed Token Count",
      "type": "integer"
    },
    "prompt": {
      "maxLength": 8192,
      "minLength": 1,
      "title": "Prompt",
      "type": "string"
    },
    "prompt_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Prompt Sha256",
      "type": "string"
    },
    "raw_output_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Raw Output Sha256",
      "type": "string"
    },
    "reasoning_content": {
      "maxLength": 24576,
      "minLength": 1,
      "title": "Reasoning Content",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "split": {
      "const": "pilot_train",
      "title": "Split",
      "type": "string"
    },
    "task_family": {
      "enum": [
        "config",
        "json",
        "linux",
        "log_diagnosis",
        "python"
      ],
      "title": "Task Family",
      "type": "string"
    },
    "task_id": {
      "pattern": "^m5-reasoning:pilot:[a-z0-9][a-z0-9._-]{2,95}$",
      "title": "Task Id",
      "type": "string"
    },
    "template_family": {
      "pattern": "^pilot\\.[a-z0-9][a-z0-9._-]+\\.v1$",
      "title": "Template Family",
      "type": "string"
    },
    "verification_id": {
      "pattern": "^m5-reasoning:pilot:[a-z0-9][a-z0-9._-]{2,95}:verify-[01]$",
      "title": "Verification Id",
      "type": "string"
    }
  },
  "required": [
    "id",
    "task_id",
    "task_family",
    "language",
    "split",
    "template_family",
    "prompt",
    "reasoning_content",
    "final_answer",
    "generation_id",
    "verification_id",
    "prompt_sha256",
    "raw_output_sha256",
    "content_sha256",
    "observed_token_count"
  ],
  "title": "ReasoningSample",
  "type": "object"
}

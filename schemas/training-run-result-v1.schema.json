{
  "additionalProperties": false,
  "description": "Terminal state of one single-device CLI invocation.",
  "properties": {
    "artifact_dir": {
      "format": "path",
      "title": "Artifact Dir",
      "type": "string"
    },
    "checkpoint_id": {
      "pattern": "^checkpoint-step-\\d{8}$",
      "title": "Checkpoint Id",
      "type": "string"
    },
    "device": {
      "title": "Device",
      "type": "string"
    },
    "global_step": {
      "minimum": 0,
      "title": "Global Step",
      "type": "integer"
    },
    "resume_mode": {
      "enum": [
        "none",
        "exact",
        "warm",
        "transfer"
      ],
      "title": "Resume Mode",
      "type": "string"
    },
    "resumed_from_step": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Resumed From Step"
    },
    "run_id": {
      "pattern": "^(?P<timestamp>\\d{8}T\\d{6}Z)-(?P<slug>[a-z0-9]+(?:-[a-z0-9]+)*)-(?P<config_hash>[a-f0-9]{8})-(?P<nonce>[a-f0-9]{4})$",
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "skipped_invalid_checkpoints": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Skipped Invalid Checkpoints",
      "type": "array"
    },
    "status": {
      "enum": [
        "succeeded",
        "terminated"
      ],
      "title": "Status",
      "type": "string"
    }
  },
  "required": [
    "status",
    "run_id",
    "artifact_dir",
    "device",
    "global_step",
    "checkpoint_id",
    "resume_mode"
  ],
  "title": "TrainingRunResult",
  "type": "object"
}
